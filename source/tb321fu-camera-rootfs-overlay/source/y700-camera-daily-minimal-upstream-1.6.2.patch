+static int y700_read_display_rotation()
+{
+	int rotation;
+
+	y700_display_rotation_watch_init();
+	if (!y700_display_rotation_initialized) {
+		if (y700_query_kscreen_rotation(&rotation))
+			y700_cached_display_rotation = rotation;
+		y700_display_rotation_initialized = true;
+		return y700_cached_display_rotation;
+	}
+	if (y700_display_rotation_watch_changed() && y700_query_kscreen_rotation(&rotation))
+		y700_cached_display_rotation = rotation;
+	return y700_cached_display_rotation;
+}
