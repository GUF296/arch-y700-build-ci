+static uint32_t y700_rotate_spa_transform(uint32_t transform, int ccw_delta)
+{
+	if (transform <= SPA_META_TRANSFORMATION_270)
+		return (transform + ccw_delta + 4) & 3;
+	return transform;
+}
+
+static uint32_t y700_effective_spa_transform(struct impl *impl, uint32_t transform)
+{
+	int display_rotation;
+	int display_ccw;
+
+	if (!y700_camera(impl))
+		return transform;
+	display_rotation = y700_read_display_rotation();
+	display_ccw = y700_kscreen_rotation_to_ccw_quarters(display_rotation);
+	display_ccw += y700_calibrated_extra_delta(impl, display_rotation);
+	return y700_rotate_spa_transform(transform, display_ccw);
+}
