+static int y700_kscreen_rotation_to_ccw_quarters(int rotation)
+{
+	switch (rotation) {
+	case 1: return 0;
+	case 2: return 1;
+	case 4: return 2;
+	case 8: return 3;
+	default: return 0;
+	}
+}
