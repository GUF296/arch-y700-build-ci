+static bool y700_display_rotation_watch_changed()
+{
+	char buffer[1024];
+	ssize_t len;
+	bool changed = false;
+
+	if (y700_display_rotation_inotify_fd < 0)
+		return false;
+	for (;;) {
+		len = read(y700_display_rotation_inotify_fd, buffer, sizeof(buffer));
+		if (len > 0) {
+			ssize_t offset = 0;
+
+			while (offset + (ssize_t)sizeof(struct inotify_event) <= len) {
+				const struct inotify_event *event =
+					reinterpret_cast<const struct inotify_event *>(buffer + offset);
+				if (event->len > 0 && !strcmp(event->name, "kwinoutputconfig.json"))
+					changed = true;
+				offset += sizeof(struct inotify_event) + event->len;
+			}
+			continue;
+		}
+		if (len < 0 && (errno == EAGAIN || errno == EWOULDBLOCK))
+			break;
+		break;
+	}
+	return changed;
+}
